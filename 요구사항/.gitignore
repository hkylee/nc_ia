.DS_Store

# Local secrets
.env
.env.*
!.env.example

# Python cache
__pycache__/
*.py[cod]
.pycache_tmp/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage

# Generated policy artifacts and reports are intentionally tracked.
# Keep only local temp files and secret material excluded.
reports/auth/
reports/logs/
reports/screenshots/

# Local runtime locks and Office temp files
output/.locks/
input/requirements/~$*.xlsx

# Rebuildable runtime/test batch outputs
output/mock_*/
output/llm_graph_test_*/
output/policy_graph_test_*/
output/batch_*/
output/tmp_*/

# Local database sidecars
*.db-shm
*.db-wal

# Python venv
.venv/

# Claude Code 개인 설정/메모
.claude/settings.local.json
.claude/HANDOVER.md
.claude/REVIEW_CHECKLIST.md
# Rebuildable local graph database. Keep requirements.db tracked, but do not
# upload this large runtime index to GitHub.
reports/evidence/policy_graph.db

# Accidental local scratch file
/현상
