OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
OPENAI_MODEL_TOPIC_LEARNING=gpt-5.5
OPENAI_REASONING_EFFORT_TOPIC_LEARNING=high
OPENAI_REASONING_EFFORT=high
OPENAI_TIMEOUT=none
OPENAI_MAX_OUTPUT_TOKEN_RETRIES=3
OPENAI_LLM_TASK_MAX_ATTEMPTS=5
OPENAI_LLM_TASK_RETRY_BASE_SECONDS=2
OPENAI_MAX_RETRIES=5
OPENAI_RETRY_BASE_SECONDS=3
OPENAI_RETRY_MAX_SECONDS=60

# 웹 로그인/회원가입 설정입니다.
# NC_ENTRY_CODE는 회원가입 시 입력하는 초대 코드입니다.
# NC_REQUIRE_USER_APPROVAL=1 로 바꾸면 신규 가입자는 승인 전까지 로그인할 수 없습니다.
# NC_USER_DB_PATH를 비우면 reports/auth/users.sqlite3에 계정 DB가 저장됩니다.
# 운영 환경에서는 Render 영구 디스크 같은 배포와 분리된 경로를 사용하세요.
NC_ENTRY_CODE=
NC_SESSION_SECRET=
# NC_REQUIRE_USER_APPROVAL=0
# NC_USER_DB_PATH=/var/data/ncstudio/reports/auth/users.sqlite3

# 웰컴 페이지의 총 호출/총 토큰/총 비용을 OpenAI 조직 Usage/Costs API 기준으로 보려면 설정합니다.
# 설정하지 않으면 reports/logs/llm_calls.jsonl 로컬 로그 기준 추정치를 표시합니다.
# 기본은 위 OPENAI_API_KEY를 그대로 사용하지만, 해당 키에 api.usage.read 권한이 필요합니다.
# 필요할 때만 Usage/Costs API 조회 권한이 있는 전용 키로 덮어쓸 수 있습니다.
# OPENAI_USAGE_API_KEY=
# OPENAI_USAGE_DASHBOARD_ENABLED=1
# OPENAI_USAGE_LOOKBACK_DAYS=30
# OPENAI_USAGE_PROJECT_IDS=
# OPENAI_USAGE_API_KEY_IDS=

# Render 같은 외부 호스팅에서는 영구 디스크 경로를 따로 둘 수 있습니다.
# 로컬에서는 비워두면 기존 output/, reports/ 경로를 그대로 사용합니다.
# NC_OUTPUT_DIR=/var/data/ncstudio/output
# NC_REPORTS_DIR=/var/data/ncstudio/reports
# NC_REFERENCE_DB_PATH=/var/data/ncstudio/reports/evidence/reference_evidence.db
# NC_FEATURE_INVENTORY_DB_PATH=/var/data/ncstudio/reports/evidence/feature_inventory.db
# NC_TOPIC_KNOWLEDGE_DIR=/var/data/ncstudio/reports/evidence/topic_knowledge
# 웰컴 페이지의 LLM 사용 여부 공유 설정은 기본값이 미사용이며,
# 관리자가 켜거나 끈 값만 아래 영구 경로에 저장됩니다.
# NC_SITE_SETTINGS_PATH=/var/data/ncstudio/reports/site_settings.json

# API 비용 없이 전체 작성 흐름을 테스트할 때만 켜세요.
# 1로 설정하면 웹/CLI의 LLM 요청이 실제 API 대신 Mock LLM으로 처리됩니다.
NC_MOCK_LLM=0

# 역할별 기본 라우팅은 코드에서 자동 적용됩니다.
# 필요할 때만 아래처럼 특정 agent의 모델/추론 강도를 덮어쓰세요.
# OPENAI_REASONING_EFFORT_OVERVIEW=low
# OPENAI_REASONING_EFFORT_USECASES=medium
# OPENAI_REASONING_EFFORT_PROCESS=medium
# OPENAI_REASONING_EFFORT_POLICIES=medium
# OPENAI_REASONING_EFFORT_INSPECTOR_STAGE=medium
# OPENAI_REASONING_EFFORT_INSPECTOR_FINAL=high
